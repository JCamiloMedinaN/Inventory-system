generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPERADMIN
  INVENTORY_MANAGER
  AUDITOR
}

// NOTE: Agregar campo para saber si esta activo o no el usuario, para poder deshabilitarlo sin eliminarlo de la base de datos
model User {
  id              String   @id @default(uuid())
  email           String   @unique
  password        String
  username        String
  role            UserRole
  isTemporaryPass Boolean  @default(true)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       String?
  updatedBy       String?
}
